---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">

  <!-- English homepage -->
  <url>
    <loc>{{ '/en/' | absolute_url }}</loc>
    <xhtml:link rel="alternate" hreflang="en" href="{{ '/en/' | absolute_url }}"/>
    <xhtml:link rel="alternate" hreflang="pt" href="{{ '/pt/' | absolute_url }}"/>
    <xhtml:link rel="alternate" hreflang="x-default" href="{{ '/en/' | absolute_url }}"/>
  </url>

  <!-- Portuguese homepage -->
  <url>
    <loc>{{ '/pt/' | absolute_url }}</loc>
    <xhtml:link rel="alternate" hreflang="en" href="{{ '/en/' | absolute_url }}"/>
    <xhtml:link rel="alternate" hreflang="pt" href="{{ '/pt/' | absolute_url }}"/>
    <xhtml:link rel="alternate" hreflang="x-default" href="{{ '/en/' | absolute_url }}"/>
  </url>

  <!-- English blog index -->
  <url>
    <loc>{{ '/en/blog/' | absolute_url }}</loc>
    <xhtml:link rel="alternate" hreflang="en" href="{{ '/en/blog/' | absolute_url }}"/>
    <xhtml:link rel="alternate" hreflang="pt" href="{{ '/pt/blog/' | absolute_url }}"/>
    <xhtml:link rel="alternate" hreflang="x-default" href="{{ '/en/blog/' | absolute_url }}"/>
  </url>

  <!-- Portuguese blog index -->
  <url>
    <loc>{{ '/pt/blog/' | absolute_url }}</loc>
    <xhtml:link rel="alternate" hreflang="en" href="{{ '/en/blog/' | absolute_url }}"/>
    <xhtml:link rel="alternate" hreflang="pt" href="{{ '/pt/blog/' | absolute_url }}"/>
    <xhtml:link rel="alternate" hreflang="x-default" href="{{ '/en/blog/' | absolute_url }}"/>
  </url>

  <!-- Blog posts (auto-generated, paired by frontmatter `ref`) -->
  {%- for post in site.posts -%}
    {%- assign en_post = site.posts | where: "ref", post.ref | where: "lang", "en" | first -%}
    {%- assign pt_post = site.posts | where: "ref", post.ref | where: "lang", "pt" | first -%}
  <url>
    <loc>{{ post.url | absolute_url }}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
    {%- if en_post %}
    <xhtml:link rel="alternate" hreflang="en" href="{{ en_post.url | absolute_url }}"/>
    {%- endif -%}
    {%- if pt_post %}
    <xhtml:link rel="alternate" hreflang="pt" href="{{ pt_post.url | absolute_url }}"/>
    {%- endif -%}
    {%- if en_post %}
    <xhtml:link rel="alternate" hreflang="x-default" href="{{ en_post.url | absolute_url }}"/>
    {%- endif %}
  </url>
  {%- endfor %}

  <!-- Federated Learning pages (English only) -->
  <url><loc>{{ '/federated-learning/' | absolute_url }}</loc></url>
  <url><loc>{{ '/federated-learning/green/' | absolute_url }}</loc></url>
  <url><loc>{{ '/federated-learning/ops/' | absolute_url }}</loc></url>
  <url><loc>{{ '/federated-learning/threats/' | absolute_url }}</loc></url>

  <!-- VCFX page (English only) -->
  <url><loc>{{ '/vcfx/' | absolute_url }}</loc></url>

  <!-- CV page -->
  <url><loc>{{ '/cv.html' | absolute_url }}</loc></url>
</urlset>
